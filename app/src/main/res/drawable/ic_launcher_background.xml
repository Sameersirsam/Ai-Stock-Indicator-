<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- Deep dark background gradient -->
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0"
                android:startY="0"
                android:endX="108"
                android:endY="108">
                <item android:offset="0.0" android:color="#161622" />
                <item android:offset="0.5" android:color="#101016" />
                <item android:offset="1.0" android:color="#040406" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Subtle tech grid/lines -->
    <path
        android:pathData="M9,0 L9,108 M27,0 L27,108 M45,0 L45,108 M63,0 L63,108 M81,0 L81,108 M99,0 L99,108"
        android:strokeWidth="0.5"
        android:strokeColor="#1AFFE082" /> <!-- 10% Gold opacity -->
    
    <path
        android:pathData="M0,9 L108,9 M0,27 L108,27 M0,45 L108,45 M0,63 L108,63 M0,81 L108,81 M0,99 L108,99"
        android:strokeWidth="0.5"
        android:strokeColor="#1AFFE082" />
        
    <!-- Sleek background radial glow in the center -->
    <path android:pathData="M34,34h40v40h-40z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="35">
                <item android:offset="0.0" android:color="#26FFE082" /> <!-- 15% Gold Glow -->
                <item android:offset="1.0" android:color="#00000000" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
